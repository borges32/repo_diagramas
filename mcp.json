{
  "inputs": [
    {
      "type": "promptString",
      "id": "grafana-url",
      "description": "URL do Grafana",
      "password": false
    },
    {
      "type": "promptString",
      "id": "grafana-token",
      "description": "Grafana Service Account Token",
      "password": true
    }
  ],
  "servers": {
    "grafana": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-grafana"],
      "env": {
        "GRAFANA_URL": "${input:grafana-url}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${input:grafana-token}"
      }
    }
  }
}


oc rsh deploy/grafana
# dentro do pod:
curl -v -H "Authorization: Bearer $TOKEN" "$TENANT/platform/storage/query/v1/query:execute" -d '{"query":"fetch logs | limit 1"}' -H "Content-Type: application/json"
